# ------------------------------------------------------------------------------
# AZHURA CBT EXAM CLIENT - ENVIRONMENT TEMPLATE
# ------------------------------------------------------------------------------
# Salin file ini menjadi ".env.local" untuk menyesuaikan konfigurasi lokal Anda.

# 1. API SERVER CONFIGURATION
# Socket.io URL diturunkan otomatis dari VITE_API_BASE_URL (mengambil origin-nya)
VITE_API_BASE_URL=http://localhost:3000/api

# 2. DEVELOPMENT MOCK SWITCH (LEGACY)
# Lapisan mock MSW sudah dihapus; flag ini kini no-op dan dipertahankan
# hanya untuk kompatibilitas. Aplikasi selalu memakai backend asli di
# VITE_API_BASE_URL. Jalankan: bun run backend:dev
VITE_USE_MOCK=false

# 3. ANTI-CHEAT ENGINE CONFIGURATION (Hanya aktif saat VITE_ANTI_CHEAT_ENABLED=true)
VITE_ANTI_CHEAT_ENABLED=false
VITE_ANTI_CHEAT_FULLSCREEN=false
VITE_ANTI_CHEAT_BLOCK_SHORTCUTS=false
VITE_ANTI_CHEAT_DETECT_FOCUS_LOSS=false
VITE_ANTI_CHEAT_DETECT_MULTI_MONITOR=false
