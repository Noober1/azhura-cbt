# E2E test environment — copy to .env and fill in values matching backend/.env

# Backend API (must be running before e2e tests)
E2E_API_URL=http://localhost:3000/api

# Student app (Playwright starts this automatically via webServer)
E2E_BASE_URL=http://localhost:1420

# Console app (Playwright starts this automatically via webServer)
E2E_CONSOLE_URL=http://localhost:1430

# Database — must match backend/.env values exactly
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=azhura_cbt

# JWT secret — must match backend/.env (used by seed to verify connectivity)
JWT_SECRET=your_jwt_secret_here

# Redis — must match backend/.env (used to clear session claims between tests)
REDIS_URL=redis://127.0.0.1:6379
