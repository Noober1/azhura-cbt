# =============================================================================
# Azhura CBT — Docker deployment env template
# =============================================================================
# Copy this file to `.env` in the repo root, then fill in real values:
#
#     cp .env.docker.example .env
#
# `docker compose` auto-loads `.env`. NEVER commit your real `.env`.
# All values below are PLACEHOLDERS — change every secret before going live.
# =============================================================================

# --- Network ---------------------------------------------------------------
# LAN IP of THIS server. The API (:3000) and console (:80) are published only
# on this address so they are NOT reachable from the WAN/internet NIC. Find it
# with `ip addr` (the address on your LAN interface, e.g. eth1).
LAN_IP=192.168.1.10

# --- Backend → database ----------------------------------------------------
# DB_HOST/DB_PORT are overridden to the compose service in docker-compose.yml
# (mariadb:3306); kept here for completeness/clarity. DB_USER/DB_PASSWORD/
# DB_NAME MUST match the MARIADB_* values below.
DB_HOST=mariadb
DB_PORT=3306
DB_USER=azhura
DB_PASSWORD=change-me-db-password
DB_NAME=azhura_cbt

# --- MariaDB container init -------------------------------------------------
# These create the database + app user on first boot. Keep them in sync with
# DB_* above (MARIADB_DATABASE=DB_NAME, MARIADB_USER=DB_USER,
# MARIADB_PASSWORD=DB_PASSWORD).
MARIADB_ROOT_PASSWORD=change-me-root-password
MARIADB_DATABASE=azhura_cbt
MARIADB_USER=azhura
MARIADB_PASSWORD=change-me-db-password

# --- Auth ------------------------------------------------------------------
# JWT signing secret. MUST be at least 32 random characters in production
# (server requires >=16 and refuses to start otherwise). The value below is a
# placeholder the backend explicitly REJECTS on boot (contains "change_me"), so
# a forgotten secret aborts startup instead of running with a guessable key.
# Generate a real one with:
#     openssl rand -base64 48
JWT_SECRET=CHANGE_ME__generate_with__openssl_rand_base64_48

# --- Backend runtime -------------------------------------------------------
PORT=3000

# Interactive API docs (GET /api/docs). MUST stay false in production — an exam
# server should never expose its full API surface + "try it out" console during
# a live exam. Enable only on a dev/preview box.
ENABLE_API_DOCS=false

# Allowed CORS origins (comma-separated). Include the console URL as served on
# the LAN, e.g. http://192.168.1.10 (port 80) and the student app origin.
CORS_ORIGIN=http://192.168.1.10

# Version string surfaced by GET /api/info.
APP_VERSION=1.0.0

# --- Watchtower ------------------------------------------------------------
# How often (seconds) to poll the registry for new :stable images. 3600 = 1h.
WATCHTOWER_POLL_INTERVAL=3600
