PORT=3000

# MySQL / MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=azhura_cbt

# JWT — wajib, minimal 16 karakter (server gagal start jika kosong/terlalu pendek)
JWT_SECRET=ganti_dengan_secret_yang_kuat_min_32_karakter

# CORS — pisahkan dengan koma jika lebih dari satu origin.
# Student client dev = 1420, admin/supervisor console dev = 1430.
CORS_ORIGIN=http://localhost:1420,http://localhost:1430

# Redis/Valkey — registry sesi aktif untuk proteksi multi-login (#5).
# Default ke instance lokal; arahkan ke Redis/Valkey terkelola di produksi.
REDIS_URL=redis://127.0.0.1:6379

# Socket.io ENGINE ping/pong — backstop liveness di lapisan transport (deteksi
# putus keras: jaringan hilang, proses mati). Default di bawah aman untuk LAN sekolah.
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=20000

# Heartbeat APLIKASI (#9) — di atas engine ping, server kirim `heartbeat:ping`
# tiap HEARTBEAT_PING_INTERVAL_MS yang HARUS dibalas JS klien. Setelah
# HEARTBEAT_MAX_MISSES ping beruntun tak terbalas, socket diputus paksa →
# status roster (#7) jadi disconnected + grace period sesi (#5) dimulai. Tiap
# pong menyegarkan TTL/lastSeen sesi. Jaga interval di bawah TTL sesi connected
# (lihat CONNECTED_TTL di session-registry.ts, default 30s) agar klien sehat
# selalu sempat refresh. Deteksi mati ≈ HEARTBEAT_MAX_MISSES × interval.
HEARTBEAT_PING_INTERVAL_MS=10000
HEARTBEAT_MAX_MISSES=2

# Chat publik siswa (#17) — anti-spam + riwayat. Aktif/nonaktif global diatur
# lewat admin console (settings.chatEnabled), bukan di sini. Default: kirim lebih
# dari CHAT_RATE_MAX pesan dalam CHAT_RATE_WINDOW_MS → auto-mute CHAT_MUTE_MS.
CHAT_RATE_WINDOW_MS=5000
CHAT_RATE_MAX=5
CHAT_MUTE_MS=60000
CHAT_HISTORY_LIMIT=50
CHAT_MAX_LENGTH=500

# Info publik sekolah — dikembalikan oleh GET /api/info (tanpa autentikasi).
# Digunakan oleh first-run wizard di student app (#43).
SCHOOL_NAME=SMP Negeri 1 Contoh
SCHOOL_ADDRESS=Jl. Contoh No. 1, Kota Contoh
APP_VERSION=1.0.0

# Verbositas log: debug | info | warn | error (default: debug di dev, info di production)
LOG_LEVEL=debug

# Direktori file .log (access.log, warn.log, errors.log). Default: backend/logs
LOG_DIR=logs
