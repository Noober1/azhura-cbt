{
  "name": "azhura-exam-backend",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "seed": "bun run src/seed.ts",
    "migrate": "bun run src/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "bunx dotenv-cli -e .env.local -- drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.3.0",
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/jwt": "^1.3.0",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.3.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.14.1",
    "socket.io": "^4.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "ioredis-mock": "^8.13.1"
  }
}
