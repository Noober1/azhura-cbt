# ─── FRONTEND · PRODUCTION ────────────────────────────────────────────────────
# Ganti URL ini dengan domain produksi sebelum deploy

VITE_API_BASE_URL=https://api.azhura-cbt.example.com/api

# Anti-cheat — aktifkan semua di produksi
VITE_ANTI_CHEAT_ENABLED=true
VITE_ANTI_CHEAT_FULLSCREEN=true
VITE_ANTI_CHEAT_BLOCK_SHORTCUTS=true
VITE_ANTI_CHEAT_DETECT_FOCUS_LOSS=true
VITE_ANTI_CHEAT_DETECT_MULTI_MONITOR=false
