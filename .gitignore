# Logs — winston output only. Anchored so it never swallows a source folder
# named "logs" (e.g. apps/console/src/components/logs).
/backend/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr

# Runtime-uploaded exam media (user content, per-deployment — never commit)
/backend/uploads/

# Env files dengan kredensial nyata — jangan di-commit
*.local
backend/.env
# Production Docker secrets file (root .env, created from .env.docker.example).
# Anchored + plain form so it is ignored at any depth, but keep the template tracked.
.env
/.env
!.env.docker.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
